<Application x:Class="WinFillTheDoc.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WinFillTheDoc.Application.ViewModels"
             xmlns:views="clr-namespace:WinFillTheDoc.Views"
             Startup="OnStartup">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:DocumentSetupViewModel}">
            <views:DocumentSetupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:DocumentDataFormViewModel}">
            <views:DocumentDataFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConfirmationViewModel}">
            <views:ConfirmationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PlaceholderLibraryViewModel}">
            <views:PlaceholderLibraryView />
        </DataTemplate>
    </Application.Resources>
</Application>
