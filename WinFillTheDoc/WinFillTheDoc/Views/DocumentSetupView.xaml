<UserControl x:Class="WinFillTheDoc.Views.DocumentSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Новый документ" FontSize="22" FontWeight="SemiBold" Foreground="#18211D" />
        <TextBlock Grid.Row="1" Text="Выберите шаблон и, при необходимости, файл с исходными данными." Margin="0,8,0,28" Foreground="#5B665E" />

        <StackPanel Grid.Row="2">
            <TextBlock Text="DOCX-шаблон *" FontWeight="SemiBold" />
            <DockPanel Margin="0,8,0,20">
                <Button DockPanel.Dock="Right" Content="Выбрать" Command="{Binding SelectTemplateCommand}" Padding="18,8" Margin="16,0,0,0" />
                <Border Background="#F4F1EB" CornerRadius="6" Padding="12,9">
                    <TextBlock Text="{Binding TemplateFileName}" TextTrimming="CharacterEllipsis" />
                </Border>
            </DockPanel>
            <TextBlock Text="{Binding TemplateStatusMessage}" Foreground="#B42318" TextWrapping="Wrap" Margin="0,-14,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#1F6B4F" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TemplateHasError}" Value="True">
                                <Setter Property="Foreground" Value="#B42318" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="Файл с данными" FontWeight="SemiBold" />
            <DockPanel Margin="0,8,0,0">
                <Button DockPanel.Dock="Right" Content="Выбрать" Command="{Binding SelectSourceCommand}" Padding="18,8" Margin="16,0,0,0" />
                <Border Background="#F4F1EB" CornerRadius="6" Padding="12,9">
                    <TextBlock Text="{Binding SourceFileName}" TextTrimming="CharacterEllipsis" />
                </Border>
            </DockPanel>
            <TextBlock Text="Поддерживаются DOC, DOCX, PDF, XLS, XLSX и TXT. Анализ файла будет добавлен в следующем этапе." FontSize="12" Foreground="#718077" Margin="0,8,0,0" />
        </StackPanel>

        <Button Grid.Row="4" Content="Продолжить" Command="{Binding ContinueCommand}" HorizontalAlignment="Right" Padding="24,10" Background="#1F6B4F" Foreground="White" BorderThickness="0" />
    </Grid>
</UserControl>
