<UserControl x:Class="WinFillTheDoc.Views.DocumentDataFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate x:Key="TextInputTemplate">
            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="9" />
        </DataTemplate>
        <DataTemplate x:Key="ChoiceInputTemplate">
            <ComboBox ItemsSource="{Binding Options}" SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="7" />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Проверьте данные" FontSize="22" FontWeight="SemiBold" Foreground="#18211D" />
            <TextBlock Text="{Binding TemplateName, StringFormat=Шаблон: {0}}" Foreground="#5B665E" Margin="0,8,0,0" />
        </StackPanel>
        <TextBlock Grid.Row="1" Text="{Binding ValidationMessage}" Foreground="#B42318" Margin="0,20,0,8" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,10,0,20">
                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Foreground="#18211D" Margin="0,0,0,4" />
                            <ItemsControl ItemsSource="{Binding Fields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,10,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text=" *" Foreground="#B42318" Visibility="{Binding IsRequired, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#718077" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding SourceLabel}" FontSize="11" Foreground="#1F6B4F" Margin="0,3,0,6" />
                                            <ContentControl Content="{Binding}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TextInputTemplate}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChoice}" Value="True">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ChoiceInputTemplate}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                            <TextBlock Text="{Binding IssueText}" FontSize="12" Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#B42318" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                <Setter Property="Foreground" Value="#B54708" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <DockPanel Grid.Row="3" Margin="0,20,0,0">
            <Button Content="Назад" Command="{Binding BackCommand}" Padding="20,9" />
            <Button Content="Подтвердить" Command="{Binding ConfirmCommand}" DockPanel.Dock="Right" Padding="20,9" Background="#1F6B4F" Foreground="White" BorderThickness="0" />
        </DockPanel>
    </Grid>
</UserControl>
