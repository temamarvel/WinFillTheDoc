<UserControl x:Class="WinFillTheDoc.Views.DocumentDataFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Проверьте данные" FontSize="22" FontWeight="SemiBold" Foreground="#18211D" />
            <TextBlock Text="{Binding TemplateName, StringFormat=Шаблон: {0}}" Foreground="#5B665E" Margin="0,8,0,0" />
        </StackPanel>
        <TextBlock Grid.Row="1" Text="{Binding ValidationMessage}" Foreground="#B42318" Margin="0,20,0,8" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,10,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" />
                                <TextBlock Text=" *" Foreground="#B42318" Visibility="{Binding IsRequired, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="9" />
                            <TextBlock Text="{Binding Error}" Foreground="#B42318" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <DockPanel Grid.Row="3" Margin="0,20,0,0">
            <Button Content="Назад" Command="{Binding BackCommand}" Padding="20,9" />
            <Button Content="Подтвердить" Command="{Binding ConfirmCommand}" DockPanel.Dock="Right" Padding="20,9" Background="#1F6B4F" Foreground="White" BorderThickness="0" />
        </DockPanel>
    </Grid>
</UserControl>
