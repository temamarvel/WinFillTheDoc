<UserControl x:Class="WinFillTheDoc.Views.ConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Данные собраны" FontSize="22" FontWeight="SemiBold" Foreground="#18211D" />
        <TextBlock Grid.Row="1" Text="{Binding TemplateName, StringFormat=Следующим этапом эти значения будут подставлены в шаблон: {0}}" TextWrapping="Wrap" Foreground="#5B665E" Margin="0,8,0,20" />
        <DataGrid Grid.Row="2" ItemsSource="{Binding FieldValues}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Поле" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel Grid.Row="3" Margin="0,20,0,0">
            <Button Content="Начать заново" Command="{Binding StartOverCommand}" Padding="20,9" />
            <Button Content="Редактировать" Command="{Binding EditCommand}" DockPanel.Dock="Right" Padding="20,9" />
        </DockPanel>
    </Grid>
</UserControl>
