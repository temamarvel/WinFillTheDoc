<UserControl x:Class="WinFillTheDoc.Views.PlaceholderLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
            <Button DockPanel.Dock="Right" Content="Назад" Command="{Binding BackCommand}" Padding="18,8" />
            <StackPanel>
                <TextBlock Text="Библиотека плейсхолдеров" FontSize="22" FontWeight="SemiBold" Foreground="#18211D" />
                <TextBlock Text="Просмотр встроенных полей и управление пользовательскими &lt;!ключами!&gt;." Foreground="#5B665E" Margin="0,8,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <DataGrid ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ключ" Binding="{Binding Key}" Width="*" />
                    <DataGridTextColumn Header="Раздел" Binding="{Binding SectionLabel}" Width="*" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding KindLabel}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Редактор" FontSize="17" FontWeight="SemiBold" Foreground="#18211D" Margin="0,0,0,12" />
                    <TextBlock Text="Token" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Padding="9" Margin="0,6,0,12" />

                    <TextBlock Text="Название" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="9" Margin="0,6,0,12" />

                    <TextBlock Text="Описание" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Padding="9" Margin="0,6,0,12" AcceptsReturn="True" MinHeight="58" />

                    <TextBlock Text="Раздел" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Sections}" SelectedItem="{Binding Section}" Padding="7" Margin="0,6,0,12" />

                    <TextBlock Text="Источник значения" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding ValueSource}" Padding="7" Margin="0,6,0,12" />

                    <TextBlock Text="Тип ввода" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding InputKinds}" SelectedItem="{Binding InputKind}" Padding="7" Margin="0,6,0,12" />

                    <CheckBox Content="Обязательное поле" IsChecked="{Binding IsRequired}" Margin="0,0,0,12" />

                    <StackPanel Visibility="{Binding IsChoice, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Варианты choice, по одному на строку или через запятую" FontWeight="SemiBold" />
                        <TextBox Text="{Binding OptionsText, UpdateSourceTrigger=PropertyChanged}" Padding="9" Margin="0,6,0,12" AcceptsReturn="True" MinHeight="78" />
                    </StackPanel>

                    <TextBlock Text="{Binding Message}" Foreground="#B54708" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Новый" Command="{Binding NewCommand}" Padding="16,8" Margin="0,0,8,0" />
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" Padding="16,8" Margin="0,0,8,0" Background="#1F6B4F" Foreground="White" BorderThickness="0" />
                        <Button Content="Удалить" Command="{Binding DeleteCommand}" Padding="16,8" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="После изменения библиотеки текущая форма сбрасывается, чтобы значения соответствовали новому набору плейсхолдеров."
                   Foreground="#718077"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,18,0,0" />
    </Grid>
</UserControl>
