<Window x:Class="WinFillTheDoc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FillTheDoc" Width="920" Height="650" MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterScreen" Background="#F4F1EB">
    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,28">
            <TextBlock Text="FillTheDoc" FontSize="30" FontWeight="SemiBold" Foreground="#18211D" />
            <TextBlock Text="Подготовка данных для заполнения документов" FontSize="14" Foreground="#5B665E" Margin="0,6,0,0" />
        </StackPanel>
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="32">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>
